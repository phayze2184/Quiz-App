# QuizAPI API key
# Create a local .env file in the project root and replace the value below
# with your own QuizAPI key.
#
# Example access:
# import.meta.env.VITE_QUIZ_API_KEY
#
# Note:
# Vite only exposes environment variables prefixed with VITE_.
# Variables without this prefix are not available in frontend code.
# Never commit your real .env file.

VITE_QUIZ_API_KEY=your_api_key_here